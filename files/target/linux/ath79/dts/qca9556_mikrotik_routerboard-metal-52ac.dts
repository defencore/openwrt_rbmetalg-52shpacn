// SPDX-License-Identifier: GPL-2.0-or-later OR MIT
/*
 * MikroTik RouterBOARD Metal 52 ac (RBMetalG-52SHPacn)
 *
 *   SoC      : Qualcomm Atheros QCA9556 (ath79, mipsbe, 720 MHz)
 *   RAM      : 64 MB,  Flash: 16 MB SPI NOR (ISSI IS25LP128)
 *   Ethernet : 1x GbE, AR8033 SGMII PHY on bit-banged MDIO (gpio 11/12)
 *   WiFi     : single dual-band 1x1 PCIe QCA9889 (driven as QCA9887 by
 *              ath10k), 2.4 + 5 GHz, one chain via external amplifier;
 *              SoC wmac unused.
 *
 * GPIO map verified live on hardware:
 *   gpio  1  - reset button (active low)
 *   gpio  4  - piezo beeper (passive; driven by a gpioset square wave)
 *   gpio 11  - MDIO (bit-banged)
 *   gpio 12  - MDC  (bit-banged)
 *   gpio 16  - ethernet status LED (active low: lit when line is low)
 *   gpio 18  - NOR power/enable: MUST stay high. Driving it low kills SPI
 *              access to the flash. Held high by gpio-hog below; do NOT use.
 *
 * The WiFi LED and the 4-segment signal-strength bar are wired to the QCA9889
 * radio chip's own GPIOs (see the ath10k-leds node), not the SoC.
 *
 * SPI bus pinmux (read live from GPIO_OUT_FUNCTION / GPIO_IN_ENABLE0, and
 * confirmed against the stock RouterOS kernel for this board, code "g52c"):
 *   pin 5  = SPI_CS0   (NOR flash)
 *   pin 6  = SPI_CLK   (shared)
 *   pin 7  = SPI_MOSI  (shared)
 *   pin 8  = SPI_MISO  (shared; SPI_DATA_IN source in GPIO_IN_ENABLE0)
 *   pin 17 = SPI_CS2   (the ZT2046Q /CS)
 * SPI_CS1 is muxed to no pin, so the ADC is on native chip-select 2.
 *
 * A ZT2046Q (ADS7846/XPT2046-compatible 12-bit SPI ADC) provides temperature
 * and input-voltage sensing. It shares SCLK/MOSI/MISO with the boot NOR flash
 * and hangs off the controller's native SPI_CS2; see the adc@2 node. Read it
 * from user space via /dev/spidev0.2 (mode 0, >= 1.875 MHz: AHB 240 MHz / 128).
 */

#include "qca955x.dtsi"

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>

/ {
	compatible = "mikrotik,routerboard-metal-52ac", "qca,qca9556";
	model = "MikroTik RouterBOARD Metal 52 ac";

	aliases {
		mdio-gpio1 = &mdio2;
	};

	keys {
		compatible = "gpio-keys";

		reset {
			label = "reset";
			linux,code = <KEY_RESTART>;
			gpios = <&gpio 1 GPIO_ACTIVE_LOW>;
			debounce-interval = <60>;
		};
	};

	leds {
		compatible = "gpio-leds";

		eth {
			label = "green:eth";
			gpios = <&gpio 16 GPIO_ACTIVE_LOW>;
		};
	};

	/*
	 * LEDs wired to the QCA9889 radio chip's own GPIOs (exposed as the
	 * "ath10k" gpio-controller). Mapped on the device by sweeping
	 * gpiochip1: gpio0 = WiFi, gpio1..4 = signal-strength bar (low->high).
	 * Driving a line low lights the LED, hence GPIO_ACTIVE_LOW.
	 */
	ath10k-leds {
		compatible = "gpio-leds";

		wlan {
			label = "green:wlan";
			gpios = <&ath10k 0 GPIO_ACTIVE_LOW>;
			linux,default-trigger = "phy0tpt";
		};

		rssilow {
			label = "green:rssilow";
			gpios = <&ath10k 1 GPIO_ACTIVE_LOW>;
		};

		rssimediumlow {
			label = "green:rssimediumlow";
			gpios = <&ath10k 2 GPIO_ACTIVE_LOW>;
		};

		rssimedium {
			label = "green:rssimedium";
			gpios = <&ath10k 3 GPIO_ACTIVE_LOW>;
		};

		rssihigh {
			label = "green:rssihigh";
			gpios = <&ath10k 4 GPIO_ACTIVE_LOW>;
		};
	};

	/*
	 * GPIO 4 is the piezo buzzer. It is passive (needs a square wave to
	 * make sound), so it is NOT bound to the gpio-beeper driver (which can
	 * only drive a steady level). The line is left free and driven on
	 * demand with a ~2 kHz square wave via gpioset (see the bootbeep
	 * init script / runtime beeps).
	 */

	mdio2: mdio {
		compatible = "virtual,mdio-gpio";

		gpios = <&gpio 12 GPIO_ACTIVE_HIGH>, /* MDC */
			<&gpio 11 GPIO_ACTIVE_HIGH>; /* MDIO */
		#address-cells = <1>;
		#size-cells = <0>;

		phy0: ethernet-phy@0 {
			reg = <0>;
			device_type = "ethernet-phy";

			phy-mode = "sgmii";

			at803x-override-sgmii-link-check;
		};
	};
};

&gpio {
	/*
	 * Line 18 enables power to the NOR flash. Hog it high so the kernel
	 * owns it from init and no userspace request (e.g. a stray gpioset)
	 * can pull it low and break SPI access to the flash.
	 */
	nor_power_hog {
		gpio-hog;
		gpios = <18 GPIO_ACTIVE_HIGH>;
		output-high;
		line-name = "nor-power-enable";
	};
};

&eth1 {
	status = "okay";

	pll-data = <0x03000101 0x80000101 0x80001313>;
	phy-handle = <&phy0>;

	qca955x-sgmii-fixup;

	gmac-config {
		device = <&gmac>;
	};
};

&spi {
	status = "okay";
	num-cs = <3>;

	/*
	 * The ZT2046Q ADC (adc@2) sits on this same SPI bus, sharing
	 * SCLK/MOSI/MISO with the NOR flash. Its /CS is the controller's native
	 * SPI_CS2 output, which the bootloader muxes onto GPIO pin 17 (verified
	 * live via GPIO_OUT_FUNCTION: pin17 = func 0x0b = SPI_CS2). SPI_CS1 is
	 * muxed to no pin, so num-cs must be 3 to reach CS2; the ath79 SPI
	 * controller drives all three native chip-selects (CS0/CS1/CS2) via its
	 * IOC register, so no cs-gpios are needed.
	 */

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <40000000>;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			partition@0 {
				label = "RouterBoot";
				reg = <0x0 0x20000>;
				compatible = "mikrotik,routerboot-partitions";
				#address-cells = <1>;
				#size-cells = <1>;

				partition@0 {
					label = "bootloader1";
					reg = <0x0 0x0>;
					read-only;
				};

				hard_config {
					read-only;
				};

				bios {
					size = <0x1000>;
					read-only;
				};

				partition@10000 {
					label = "bootloader2";
					reg = <0x10000 0x0>;
					read-only;
				};

				soft_config {
				};
			};

			partition@20000 {
				compatible = "mikrotik,minor";
				label = "firmware";
				reg = <0x020000 0xfe0000>;
			};
		};
	};

	/*
	 * ZT2046Q (ADS7846/XPT2046-compatible 12-bit SPI ADC): temperature and
	 * input-voltage sensing on native chip-select 2 (SPI_CS2 -> pin 17).
	 * Bound to spidev (read from user space) rather than the ads7846 driver,
	 * because ads7846 needs a PENIRQ/pendown interrupt that is not wired on
	 * this board. "rohm,dh2228fv" is the conventional spidev compatible.
	 *
	 * spi-max-frequency must stay >= AHB/128 = 1.875 MHz (240 MHz AHB) or the
	 * ath79 clock divider overflows ("spi clock is too low"); the ADS7846
	 * family tops out at ~2 MHz, so 2 MHz is the usable point.
	 *
	 * Enumerates as /dev/spidev0.2. Single-ended control bytes (mode 0),
	 * shift 3 bytes [ctrl,0,0], result = top 12 bits of the last 2 bytes:
	 *   0xA7 = VBAT  (input voltage via on-board divider)
	 *   0x87 / 0xF7 = TEMP0 / TEMP1
	 *   0xE7 = AUX
	 */
	adc@2 {
		compatible = "rohm,dh2228fv";
		reg = <2>;
		spi-max-frequency = <2000000>;
	};
};

&pcie0 {
	status = "okay";

	ath10k: wifi@0,0 {
		compatible = "qcom,ath10k";
		reg = <0 0 0 0 0>;

		/*
		 * The WiFi LED + signal-strength bar are on this radio chip's
		 * own GPIOs. Expose them as a gpio-controller so they can be
		 * described as gpio-leds (see the ath10k-leds node).
		 * Requires CONFIG_ATH10K_LEDS + the gpiochip backport patch.
		 */
		#gpio-cells = <2>;
		gpio-controller;
	};
};
